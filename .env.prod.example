# NUR Project — PRODUCTION environment.
# NUSXA OLING:  cp .env.prod.example .env.prod   so'ng qiymatlarni to'ldiring.
# .env.prod ni HECH QACHON git'ga commit qilmang (.gitignore da bor).

# --- Domen (Caddy SSL shu domenga oladi) ---
DOMAIN=erp.nurtechno.uz

# --- Baza (shu droplet ichidagi postgres konteyner) ---
# POSTGRES_PASSWORD va DATABASE_URL dagi parol BIR XIL bo'lishi shart.
# Kuchli parol yarating:  openssl rand -hex 16
POSTGRES_PASSWORD=BU_YERGA_KUCHLI_PAROL
DATABASE_URL=postgresql+asyncpg://postgres:BU_YERGA_KUCHLI_PAROL@postgres:5432/nur_erp

# --- JWT maxfiy kaliti — ALBATTA o'zgartiring (tasodifiy uzun satr) ---
# Yaratish:  openssl rand -hex 32
SECRET_KEY=BU_YERGA_TASODIFIY_64_BELGILI_SATR

# --- CORS ---
# Bir domen ishlatilgani uchun odatda shart emas, lekin to'liqlik uchun:
ALLOWED_ORIGINS_STR=https://erp.nurtechno.uz

# --- Birinchi super-admin (faqat birinchi seed'da yaratiladi) ---
INIT_ADMIN_EMAIL=admin@nurtechno.uz
INIT_ADMIN_PASSWORD=ALMASHTIRING_Kuchli@Parol
INIT_ADMIN_NAME=Super Admin
