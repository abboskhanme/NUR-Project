# NUR ERP Backend - Environment Variables

# Application
APP_NAME=NurBunker ERP
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/nur_erp

# JWT
SECRET_KEY=please-change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# CBU API (O'zbekiston Markaziy banki)
CBU_API_URL=https://cbu.uz/uz/arkhiv-kursov-valyut/json/

# Initial Super Admin (seed)
INIT_ADMIN_EMAIL=admin@nurtechno.uz
INIT_ADMIN_PASSWORD=Admin@12345
INIT_ADMIN_NAME=Super Admin

# File uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=20

# --- Quyidagilar hozir ishlatilmaydi (kelajakda kerak bo'lsa qo'shing) ---
# REDIS_URL=redis://localhost:6379/0
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_WEBHOOK_URL=
