# NUR ERP Backend - Environment Variables

# Application
APP_NAME=NUR Project
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/nur_erp

# JWT — MAJBURIY: kamida 32 belgilik tasodifiy qiymat.
# Yaratish: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=please-change-me-to-a-long-random-string-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# CBU API (O'zbekiston Markaziy banki)
CBU_API_URL=https://cbu.uz/uz/arkhiv-kursov-valyut/json/

# Initial Super Admin (seed)
INIT_ADMIN_PHONE=+998901234567
INIT_ADMIN_PASSWORD=Admin@12345
INIT_ADMIN_NAME=Super Admin

# File uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=20

# --- Telegram bot (app/integrations/telegram) ---
# BotFather'dan olingan token. Bo'sh bo'lsa bot ishga tushmaydi.
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# Kunlik hisobot oluvchi xo'jayin chat_id(lari), vergul bilan. Bot'ga /id yuborib biling.
# TELEGRAM_ADMIN_CHAT_IDS=123456789,987654321
# Kunlik hisobot vaqti (HH:MM, TIMEZONE bo'yicha)
# TELEGRAM_REPORT_TIME=20:00
# Yangi buyurtmada xo'jayinga darhol xabar (true/false)
# TELEGRAM_NOTIFY_NEW_ORDER=true
# TIMEZONE=Asia/Tashkent

# --- Quyidagilar hozir ishlatilmaydi (kelajakda kerak bo'lsa qo'shing) ---
# REDIS_URL=redis://localhost:6379/0
# TELEGRAM_WEBHOOK_URL=
